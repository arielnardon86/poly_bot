# ============================================================
# POLYMARKET BOT - CONFIGURACION
# Copia este archivo a .env y rellena con tus valores reales
# NUNCA subas .env a git
# ============================================================

# --- WALLET ---
# Tu private key de MetaMask (sin el 0x del inicio)
PRIVATE_KEY=tu_private_key_aqui

# Tu dirección pública de wallet (con el 0x)
WALLET_ADDRESS=0x_tu_direccion_aqui

# --- POLYMARKET API (se generan automáticamente con setup_credentials.py) ---
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# --- CONFIGURACION DEL BOT ---
# Cuánto USDC máximo arriesgar por operación (en dólares)
MAX_POSITION_SIZE=50

# Mínimo rendimiento neto requerido para ejecutar una operación (ej: 0.03 = 3%)
MIN_ROI=0.03

# Modo de prueba: True = solo simula, no ejecuta órdenes reales
DRY_RUN=True

# Capital inicial que depositaste (en USDC) — solo para calcular rendimiento total
INITIAL_CAPITAL=200

# --- DASHBOARD ---
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=tu_password_aqui
DASHBOARD_SECRET_KEY=una_clave_secreta_larga_y_aleatoria
